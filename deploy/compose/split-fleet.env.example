RUST_LOG=info

# shared operator-state backend
BURN_P2P_OPERATOR_STATE_POSTGRES_URL=postgres://burn_p2p:burn-p2p-dev@burn-p2p-postgres:5432/burn_p2p
BURN_P2P_OPERATOR_STATE_POSTGRES_TABLE=burn_p2p_operator_state_snapshots
BURN_P2P_OPERATOR_STATE_KEY_PREFIX=burn-p2p:operator-state
# optional compatibility path if you intentionally want the older redis-backed
# mirrored snapshot mode instead of postgres.
BURN_P2P_OPERATOR_STATE_REDIS_URL=

# browser-edge auth/session redis
BURN_P2P_AUTH_SESSION_REDIS_URL=redis://burn-p2p-redis:6379/0

# provider secrets
BURN_P2P_GITHUB_CLIENT_ID=
BURN_P2P_GITHUB_CLIENT_SECRET=
BURN_P2P_GITHUB_REDIRECT_URI=https://edge.example/callback/github
BURN_P2P_OIDC_ISSUER=https://issuer.example
BURN_P2P_OIDC_AUTHORIZE_BASE_URL=https://issuer.example/authorize
BURN_P2P_OIDC_TOKEN_URL=https://issuer.example/oauth/token
BURN_P2P_OIDC_CLIENT_ID=burn-p2p-browser-edge
BURN_P2P_OIDC_CLIENT_SECRET=
BURN_P2P_OIDC_REDIRECT_URI=https://edge.example/callback/oidc

# packaged postgres module for the shared operator-state backend
BURN_P2P_OPERATOR_STATE_POSTGRES_DB=burn_p2p
BURN_P2P_OPERATOR_STATE_POSTGRES_USER=burn_p2p
BURN_P2P_OPERATOR_STATE_POSTGRES_PASSWORD=burn-p2p-dev

# packaged minio / s3-compatible artifact publication module
BURN_P2P_ARTIFACT_S3_ENDPOINT=http://burn-p2p-minio:9000
BURN_P2P_ARTIFACT_S3_BUCKET=burn-p2p-artifacts
BURN_P2P_ARTIFACT_S3_REGION=us-east-1
BURN_P2P_ARTIFACT_S3_ACCESS_KEY_ID=burn-p2p
BURN_P2P_ARTIFACT_S3_SECRET_ACCESS_KEY=burn-p2p-dev-secret
BURN_P2P_ARTIFACT_S3_PATH_PREFIX=artifacts
BURN_P2P_ARTIFACT_S3_SERVER_SIDE_ENCRYPTION=AES256

# bootstrap build
BURN_P2P_BOOTSTRAP_FEATURES=admin-http,metrics

# validator build
BURN_P2P_VALIDATOR_FEATURES=admin-http,metrics

# reducer build
BURN_P2P_REDUCER_FEATURES=admin-http,metrics

# trainer app build
# point these at the downstream application that actually embeds your workload.
BURN_P2P_TRAINER_APP_MANIFEST_PATH=crates/burn_p2p/Cargo.toml
BURN_P2P_TRAINER_APP_TARGET_KIND=example
BURN_P2P_TRAINER_APP_TARGET_NAME=synthetic_trainer
BURN_P2P_TRAINER_APP_FEATURES=burn
BURN_P2P_TRAINER_APP_NO_DEFAULT_FEATURES=false

# trainer commands/configs
BURN_P2P_TRAINER_CPU_CONFIG_PATH=./trainer.json
BURN_P2P_TRAINER_CPU_COMMAND=/config/trainer.json
BURN_P2P_TRAINER_GPU_CONFIG_PATH=./trainer-gpu.json
BURN_P2P_TRAINER_GPU_COMMAND=/config/trainer-gpu.json
