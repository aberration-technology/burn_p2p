aws_region = "us-east-1"
name_prefix = "burn-p2p-demo"
subnet_id = "subnet-0123456789abcdef0"

bootstrap_count = 2
validator_count = 1
reducer_count = 1
trainer_count = 1

bootstrap_instance_type = "t3.small"
validator_instance_type = "t3.large"
reducer_instance_type = "t3.large"
trainer_instance_type = "g4dn.xlarge"

ssh_cidrs = ["203.0.113.10/32"]
bootstrap_public_ip_enabled = true
validator_public_ip_enabled = false
reducer_public_ip_enabled = false
trainer_public_ip_enabled = false

bootstrap_public_cidrs = ["0.0.0.0/0"]
bootstrap_public_tcp_ports = [4001]
bootstrap_public_udp_ports = [4001]
